{
  "manifest_version": 3,
  "name": "Scrubbed — Rate YouTube Videos",
  "version": "1.0.0",
  "description": "Rate any YouTube video you watch, without leaving the page.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://YOUR-PROJECT.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["config.js", "auth.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrubbed"
  }
}
